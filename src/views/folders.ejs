<%- include('header') %>

    <style>
        /* ===== Layout ===== */
        .folders-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
            flex-wrap: wrap;
        }

        /* ===== Alert ===== */
        .alert {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        .alert-success {
            background: rgba(34, 197, 94, .15);
            border: 1px solid rgba(34, 197, 94, .3);
            color: #4ade80;
        }

        .alert-danger {
            background: rgba(239, 68, 68, .15);
            border: 1px solid rgba(239, 68, 68, .3);
            color: #f87171;
        }

        .alert-warning {
            background: rgba(251, 191, 36, .15);
            border: 1px solid rgba(251, 191, 36, .3);
            color: #fbbf24;
        }

        /* ===== Explorer Card ===== */
        .explorer-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        .explorer-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.85rem 1.2rem;
            border-bottom: 1px solid var(--border-color);
            background: var(--bg-tertiary);
        }

        .explorer-header-title {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .explorer-header .ml-auto {
            margin-left: auto;
        }

        .explorer-empty {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .explorer-empty .empty-icon {
            font-size: 3rem;
            margin-bottom: 0.75rem;
            opacity: 0.5;
        }

        /* ===== Server Group ===== */
        .server-group {
            border-bottom: 1px solid var(--border-color);
        }

        .server-group:last-child {
            border-bottom: none;
        }

        .server-group-label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            padding: 0.5rem 1rem;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid var(--border-color);
            cursor: pointer;
            user-select: none;
            transition: background .12s;
        }

        .server-group-label:hover {
            background: rgba(255, 255, 255, 0.06);
        }

        .server-group-label .sg-chevron {
            font-size: 0.6rem;
            transition: transform .2s;
            color: var(--text-muted);
            flex-shrink: 0;
        }

        .server-group-label .sg-chevron.sg-open {
            transform: rotate(90deg);
        }

        .server-group-content {
            /* visible by default */
        }

        .server-group-content.sg-collapsed {
            display: none;
        }

        /* ===== Folder Tree ===== */
        .folder-tree {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .folder-tree .folder-tree {
            padding-left: 0;
            margin-left: 22px;
            border-left: 1px dashed var(--border-color);
        }

        .folder-node {
            margin: 0;
        }

        .folder-row {
            display: flex;
            align-items: center;
            padding: 0.28rem 1rem 0.28rem 0.5rem;
            transition: background .12s;
            cursor: default;
            user-select: none;
            min-height: 36px;
        }

        .folder-row:hover {
            background: var(--bg-tertiary);
        }

        .toggle-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            font-size: 0.65rem;
            transition: transform .18s;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            margin-right: 2px;
        }

        .toggle-btn:hover {
            background: var(--bg-tertiary);
            color: var(--text-primary);
        }

        .toggle-btn.open {
            transform: rotate(90deg);
        }

        .toggle-placeholder {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            margin-right: 2px;
        }

        .folder-icon {
            font-size: 1rem;
            margin-right: 6px;
            flex-shrink: 0;
            line-height: 1;
        }

        .folder-name {
            flex: 1;
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .folder-path-chip {
            font-size: 0.7rem;
            color: var(--text-muted);
            background: var(--bg-tertiary);
            padding: 1px 7px;
            border-radius: 20px;
            margin-left: 6px;
            flex-shrink: 0;
            max-width: 260px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* ===== Folder Actions (hidden, show on hover) ===== */
        .folder-actions {
            display: flex;
            gap: 3px;
            margin-left: 8px;
            flex-shrink: 0;
            opacity: 0;
            transition: opacity .15s;
        }

        .folder-row:hover .folder-actions {
            opacity: 1;
        }

        .action-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 0.78rem;
            color: var(--text-muted);
            transition: background .12s, color .12s;
            display: flex;
            align-items: center;
            gap: 3px;
            white-space: nowrap;
        }

        .action-btn:hover {
            color: var(--text-primary);
            background: rgba(255, 255, 255, 0.08);
        }

        .action-btn.danger:hover {
            color: #f87171;
            background: rgba(239, 68, 68, 0.12);
        }

        .action-btn.success:hover {
            color: #4ade80;
            background: rgba(34, 197, 94, 0.12);
        }

        /* ===== Children collapse ===== */
        .children-list.collapsed {
            display: none;
        }

        /* ===== Modal ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .6);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            backdrop-filter: blur(4px);
        }

        .modal-overlay.is-open {
            display: flex;
        }

        .modal {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            width: 460px;
            max-width: 95vw;
            box-shadow: 0 24px 70px rgba(0, 0, 0, .5);
            animation: modal-in .18s ease;
        }

        @keyframes modal-in {
            from {
                opacity: 0;
                transform: scale(.96) translateY(-10px);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 1.4rem;
            border-bottom: 1px solid var(--border-color);
        }

        .modal-header h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 600;
        }

        .modal-close {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 1.1rem;
            line-height: 1;
            border-radius: 6px;
            padding: 4px 7px;
            transition: background .12s, color .12s;
        }

        .modal-close:hover {
            background: var(--bg-tertiary);
            color: var(--text-primary);
        }

        .modal-body {
            padding: 1.4rem;
        }

        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
            padding: 1rem 1.4rem;
            border-top: 1px solid var(--border-color);
        }

        .modal-breadcrumb {
            font-size: 0.78rem;
            color: var(--text-muted);
            background: var(--bg-tertiary);
            border-radius: 6px;
            padding: 6px 10px;
            margin-bottom: 1rem;
            font-family: monospace;
            word-break: break-all;
        }

        .hint-text {
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 0.35rem;
        }

        /* ===== Custom Checkbox ===== */
        .custom-cb {
            position: relative;
            display: inline-flex;
            align-items: center;
            cursor: pointer;
            margin-right: 6px;
            flex-shrink: 0;
        }
        .custom-cb input {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }
        .custom-cb .cb-mark {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,.25);
            border-radius: 4px;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s ease;
            position: relative;
        }
        .custom-cb:hover .cb-mark {
            border-color: rgba(99,102,241,.6);
            background: rgba(99,102,241,.08);
        }
        .custom-cb input:checked + .cb-mark {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            border-color: #6366f1;
            box-shadow: 0 0 6px rgba(99,102,241,.35);
        }
        .custom-cb input:checked + .cb-mark::after {
            content: '';
            width: 4px;
            height: 8px;
            border: solid #fff;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg);
            margin-top: -1px;
        }

        /* ===== Folder Picker (custom tree) ===== */
        .folder-picker-search {
            width: 100%;
            padding: 6px 10px;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            background: var(--bg-tertiary);
            color: var(--text-primary);
            font-size: 0.82rem;
            margin-bottom: 0.5rem;
            outline: none;
        }
        .folder-picker-search:focus {
            border-color: rgba(99,102,241,.5);
        }
        .folder-picker-container {
            max-height: 280px;
            overflow-y: auto;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: var(--bg-tertiary);
        }
        .fp-item {
            display: flex;
            align-items: center;
            padding: 4px 8px;
            cursor: pointer;
            font-size: 0.82rem;
            transition: background .1s;
            border-radius: 4px;
            margin: 1px 4px;
            color: var(--text-primary);
        }
        .fp-item:hover {
            background: rgba(255,255,255,.06);
        }
        .fp-item.fp-selected {
            background: rgba(99,102,241,.2);
            outline: 1px solid rgba(99,102,241,.4);
        }
        .fp-item .fp-toggle {
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.55rem;
            color: var(--text-muted);
            cursor: pointer;
            flex-shrink: 0;
            border-radius: 3px;
            transition: transform .15s;
        }
        .fp-item .fp-toggle:hover {
            background: rgba(255,255,255,.08);
        }
        .fp-item .fp-toggle.fp-open {
            transform: rotate(90deg);
        }
        .fp-children {
            padding-left: 16px;
        }
        .fp-children.fp-hidden {
            display: none;
        }
        .fp-root-option {
            padding: 6px 10px;
            cursor: pointer;
            font-size: 0.82rem;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-color);
            transition: background .1s;
        }
        .fp-root-option:hover {
            background: rgba(255,255,255,.06);
        }
        .fp-root-option.fp-selected {
            background: rgba(99,102,241,.2);
        }
        .fp-no-results {
            padding: 1rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.82rem;
        }
        .fp-server-header {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            padding: 6px 10px 3px;
            background: rgba(255,255,255,.02);
            border-top: 1px solid var(--border-color);
            cursor: default;
            user-select: none;
        }
        .fp-server-header:first-child {
            border-top: none;
        }
    </style>

    <div class="page-header">
        <h1 class="page-title">📁 Quản lí Thư mục</h1>
    </div>

    <% if (queryError) { %>
        <div class="alert alert-danger">
            <%= queryError %>
        </div>
        <% } %>
            <% if (querySuccess) { %>
                <div class="alert alert-success">✅ Thao tác thành công!</div>
                <% } %>
                    <% if (servers.length===0) { %>
                        <div class="alert alert-warning">⚠️ Chưa có server nào. <a href="/servers">Thêm server</a>
                            trước.</div>
                        <% } %>

                            <!-- Toolbar -->
                            <div class="folders-toolbar">
                                <% if (servers.length> 0) { %>
                                    <button class="btn btn-primary" onclick="openCreateModal(null,null,null)"
                                        id="btnCreateRoot">
                                        ➕ Tạo thư mục gốc
                                    </button>
                                    <% } %>
                            </div>

                            <!-- Bulk action toolbar -->
                            <div id="bulkFolderToolbar" style="display:none;align-items:center;gap:.75rem;background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);border-radius:8px;padding:.6rem 1rem;margin-bottom:.75rem;flex-wrap:wrap">
                                <span id="bulkFolderCount" style="font-size:.85rem;color:var(--text-secondary);font-weight:500">0 đã chọn</span>
                                <button class="btn btn-primary btn-sm" onclick="openBulkMoveModal()">📦 Di chuyển đã chọn</button>
                                <button class="btn btn-secondary btn-sm" onclick="clearFolderSelection()">✕ Bỏ chọn</button>
                            </div>

                            <!-- Explorer -->
                            <div class="explorer-card">
                                <div class="explorer-header">
                                    <span>🌲</span>
                                    <span class="explorer-header-title">Cây Thư mục</span>
                                    <span class="ml-auto" style="display:flex;align-items:center;gap:6px">
                                        <span style="font-size:0.78rem;color:var(--text-muted);margin-right:6px">Hover
                                            để thấy tùy chọn</span>
                                        <button class="action-btn" onclick="expandAll()" title="Mở rộng tất cả"
                                            style="opacity:1;padding:3px 10px">⊞ Mở tất cả</button>
                                        <button class="action-btn" onclick="collapseAll()" title="Thu gọn tất cả"
                                            style="opacity:1;padding:3px 10px">⊟ Thu gọn</button>
                                    </span>
                                </div>

                                <% if (folders.length===0) { %>
                                    <div class="explorer-empty">
                                        <div class="empty-icon">📂</div>
                                        <div>Chưa có thư mục nào</div>
                                        <% if (servers.length> 0) { %>
                                            <button class="btn btn-primary" style="margin-top:1rem"
                                                onclick="openCreateModal(null,null,null)">
                                                ➕ Tạo thư mục đầu tiên
                                            </button>
                                            <% } %>
                                    </div>
                                    <% } else { %>
                                        <% folderTrees.forEach(function(treeData) { %>
                                            <div class="server-group">
                                                <div class="server-group-label" onclick="toggleServerGroup(this)" data-server-id="<%= treeData.server.id %>">
                                                    <span class="sg-chevron">▶</span>
                                                    🖥️ <%= treeData.server.name %>
                                                        <span
                                                            style="font-weight:400;text-transform:none;letter-spacing:0;opacity:.6;margin-left:4px">
                                                            (<%= treeData.server.type %>)
                                                        </span>
                                                        <span style="font-weight:400;text-transform:none;letter-spacing:0;opacity:.5;margin-left:2px;font-size:.72rem">
                                                            — <%= treeData.roots.length %> thư mục
                                                        </span>
                                                        <% if (isAdmin) { %>
                                                            <button class="action-btn success"
                                                                style="opacity:1;margin-left:auto"
                                                                onclick="event.stopPropagation();openCreateModal(null,null,<%- treeData.server.id %>)"
                                                                title="Tạo thư mục gốc trên server này">➕ Tạo thư mục
                                                                gốc</button>
                                                            <% } %>
                                                </div>
                                                <div class="server-group-content sg-collapsed" data-sg-server="<%= treeData.server.id %>">
                                                <% if (treeData.roots.length===0) { %>
                                                    <div
                                                        style="padding:.75rem 1rem;font-size:.82rem;color:var(--text-muted);font-style:italic">
                                                        📂 Chưa có thư mục nào trên server này
                                                    </div>
                                                    <% } else { %>
                                                        <ul class="folder-tree"><%- renderTree(treeData.roots,
                                                                treeData.server.id) %></ul>
                                                        <% } %>
                                                </div>
                                            </div>
                                            <% }); %>
                                                <% } %>
                            </div>


                            <!-- ===== Modal: Tạo thư mục ===== -->
                            <div class="modal-overlay" id="createModal">
                                <div class="modal">
                                    <div class="modal-header">
                                        <h3 id="createModalTitle">🗂️ Tạo thư mục mới</h3>
                                        <button class="modal-close" onclick="closeModal('createModal')">✕</button>
                                    </div>
                                    <form method="POST" action="/folders/add" id="createForm">
                                        <input type="hidden" name="parent_id" id="createParentId" value="">
                                        <input type="hidden" name="server_id" id="createServerId" value="">
                                        <div class="modal-body">
                                            <div class="modal-breadcrumb" id="createBreadcrumb" style="display:none">
                                                📍 Trong: <strong id="createBreadcrumbText"></strong>
                                            </div>
                                            <div class="form-group" id="serverSelectGroup">
                                                <label class="form-label">Server *</label>
                                                <select id="createServerSelect" class="form-control">
                                                    <option value="">-- Chọn server --</option>
                                                    <% servers.forEach(function(s) { %>
                                                        <option value="<%= s.id %>">
                                                            <%= s.name %>
                                                        </option>
                                                        <% }); %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Tên thư mục *</label>
                                                <input type="text" name="name" id="createNameInput" class="form-control"
                                                    placeholder="vd: phim-hanh-dong" required autocomplete="off">
                                                <div class="hint-text" id="createPathHint"></div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline"
                                                onclick="closeModal('createModal')">Hủy</button>
                                            <button type="submit" class="btn btn-primary">🗂️ Tạo thư mục</button>
                                        </div>
                                    </form>
                                </div>
                            </div>


                            <!-- ===== Modal: Đổi tên ===== -->
                            <div class="modal-overlay" id="renameModal">
                                <div class="modal">
                                    <div class="modal-header">
                                        <h3>✏️ Đổi tên thư mục</h3>
                                        <button class="modal-close" onclick="closeModal('renameModal')">✕</button>
                                    </div>
                                    <form method="POST" id="renameForm">
                                        <div class="modal-body">
                                            <div class="modal-breadcrumb" id="renameBreadcrumb"></div>
                                            <div class="form-group" style="margin-top:.75rem">
                                                <label class="form-label">Tên mới *</label>
                                                <input type="text" name="name" id="renameInput" class="form-control"
                                                    required autocomplete="off">
                                            </div>
                                            <p class="hint-text">⚠️ Đổi tên sẽ cập nhật path của tất cả thư mục con.</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline"
                                                onclick="closeModal('renameModal')">Hủy</button>
                                            <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
                                        </div>
                                    </form>
                                </div>
                            </div>


                            <!-- ===== Modal: Di chuyển thư mục ===== -->
                            <div class="modal-overlay" id="moveModal">
                                <div class="modal">
                                    <div class="modal-header">
                                        <h3>📦 Di chuyển thư mục</h3>
                                        <button class="modal-close" onclick="closeModal('moveModal')">✕</button>
                                    </div>
                                    <form method="POST" id="moveForm">
                                        <div class="modal-body">
                                            <div class="modal-breadcrumb" id="moveBreadcrumb"></div>
                                            <div class="form-group" style="margin-top:.75rem">
                                                <label class="form-label">Thư mục cha mới *</label>
                                                <input type="hidden" name="new_parent_id" id="moveParentValue" value="">
                                                <input type="text" class="folder-picker-search" id="moveSearch" placeholder="🔍 Tìm thư mục..." autocomplete="off">
                                                <div class="folder-picker-container" id="movePickerContainer"></div>
                                            </div>
                                            <p class="hint-text">⚠️ Toàn bộ thư mục con sẽ được cập nhật path theo.</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline" onclick="closeModal('moveModal')">Hủy</button>
                                            <button type="submit" class="btn btn-primary">📦 Di chuyển</button>
                                        </div>
                                    </form>
                                </div>
                            </div>


                            <!-- ===== Modal: Bulk Move ===== -->
                            <div class="modal-overlay" id="bulkMoveModal">
                                <div class="modal">
                                    <div class="modal-header">
                                        <h3>📦 Di chuyển hàng loạt</h3>
                                        <button class="modal-close" onclick="closeModal('bulkMoveModal')">✕</button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="modal-breadcrumb" id="bulkMoveSummary"></div>
                                        <div class="form-group" style="margin-top:.75rem">
                                            <label class="form-label">Thư mục đích *</label>
                                            <input type="hidden" id="bulkMoveTargetValue" value="">
                                            <input type="text" class="folder-picker-search" id="bulkMoveSearch" placeholder="🔍 Tìm thư mục..." autocomplete="off">
                                            <div class="folder-picker-container" id="bulkMovePickerContainer"></div>
                                        </div>
                                        <p class="hint-text">⚠️ Toàn bộ thư mục con sẽ được cập nhật path theo.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-outline" onclick="closeModal('bulkMoveModal')">Hủy</button>
                                        <button type="button" class="btn btn-primary" id="bulkMoveSubmitBtn" onclick="submitBulkMove()">📦 Di chuyển</button>
                                    </div>
                                </div>
                            </div>

                            <div id="__foldersData" data-json="<%= foldersJson.replace(/\" /g, '&quot;' ) %>"
                                style="display:none"></div>

                            <script>
                                var folderData = JSON.parse(document.getElementById('__foldersData').dataset.json || '[]');

                                function closeModal(id) {
                                    document.getElementById(id).classList.remove('is-open');
                                }

                                ['createModal', 'renameModal', 'moveModal', 'bulkMoveModal'].forEach(function (id) {
                                    document.getElementById(id).addEventListener('click', function (e) {
                                        if (e.target === this) closeModal(id);
                                    });
                                });

                                document.addEventListener('keydown', function (e) {
                                    if (e.key === 'Escape') {
                                        closeModal('createModal');
                                        closeModal('renameModal');
                                        closeModal('moveModal');
                                        closeModal('bulkMoveModal');
                                    }
                                });

                                function openCreateModal(parentId, parentPath, serverId) {
                                    var title = document.getElementById('createModalTitle');
                                    var breadcrumb = document.getElementById('createBreadcrumb');
                                    var breadcrumbT = document.getElementById('createBreadcrumbText');
                                    var serverGroup = document.getElementById('serverSelectGroup');
                                    var serverSel = document.getElementById('createServerSelect');
                                    var serverHid = document.getElementById('createServerId');
                                    var parentHid = document.getElementById('createParentId');
                                    var nameInput = document.getElementById('createNameInput');
                                    var pathHint = document.getElementById('createPathHint');

                                    nameInput.value = '';
                                    parentHid.value = parentId || '';
                                    serverHid.value = serverId || '';

                                    if (parentId) {
                                        title.textContent = 'Tạo thư mục con';
                                        breadcrumb.style.display = 'block';
                                        breadcrumbT.textContent = parentPath;
                                        serverGroup.style.display = 'none';
                                        serverSel.required = false;
                                        pathHint.textContent = 'Sẽ tạo trong: ' + parentPath;
                                    } else if (serverId) {
                                        // Called from inline button on server header — pre-select server
                                        title.textContent = 'Tạo thư mục gốc';
                                        breadcrumb.style.display = 'none';
                                        serverSel.value = String(serverId);
                                        serverGroup.style.display = 'none';
                                        serverSel.required = false;
                                        pathHint.textContent = '';
                                    } else {
                                        title.textContent = 'Tạo thư mục gốc';
                                        breadcrumb.style.display = 'none';
                                        serverGroup.style.display = 'block';
                                        serverSel.required = true;
                                        serverSel.value = '';
                                        serverHid.value = '';
                                        pathHint.textContent = '';
                                    }

                                    document.getElementById('createModal').classList.add('is-open');
                                    setTimeout(function () { nameInput.focus(); }, 80);
                                }

                                document.getElementById('createServerSelect').addEventListener('change', function () {
                                    document.getElementById('createServerId').value = this.value;
                                });

                                function openRename(id, name, path) {
                                    document.getElementById('renameInput').value = name;
                                    document.getElementById('renameForm').action = '/folders/rename/' + id;
                                    document.getElementById('renameBreadcrumb').textContent = '> ' + path;
                                    document.getElementById('renameModal').classList.add('is-open');
                                    setTimeout(function () {
                                        var inp = document.getElementById('renameInput');
                                        inp.focus(); inp.select();
                                    }, 80);
                                }

                                // ── Shared: Build tree picker ──────
                                function buildFolderTree(folders) {
                                    var byId = {};
                                    folders.forEach(function(f) { byId[f.id] = { id: f.id, name: f.name, path: f.path, parent_id: f.parent_id, children: [] }; });
                                    var roots = [];
                                    folders.forEach(function(f) {
                                        if (f.parent_id && byId[f.parent_id]) byId[f.parent_id].children.push(byId[f.id]);
                                        else roots.push(byId[f.id]);
                                    });
                                    roots.sort(function(a, b) { return a.name.localeCompare(b.name); });
                                    return roots;
                                }

                                function renderPickerTree(nodes, depth) {
                                    var html = '';
                                    nodes.sort(function(a, b) { return a.name.localeCompare(b.name); });
                                    nodes.forEach(function(node) {
                                        var hasKids = node.children && node.children.length > 0;
                                        var pad = depth * 16;
                                        html += '<div class="fp-item" data-id="' + node.id + '" data-name="' + node.name + '" data-path="' + node.path + '" style="padding-left:' + (8 + pad) + 'px" onclick="selectPickerItem(this)" title="' + node.path + '">';
                                        if (hasKids) {
                                            html += '<span class="fp-toggle" onclick="event.stopPropagation();togglePickerNode(this)">▶</span>';
                                        } else {
                                            html += '<span style="width:18px;flex-shrink:0"></span>';
                                        }
                                        html += '<span style="margin:0 4px">📁</span>' + node.name;
                                        html += '</div>';
                                        if (hasKids) {
                                            html += '<div class="fp-children fp-hidden">' + renderPickerTree(node.children, depth + 1) + '</div>';
                                        }
                                    });
                                    return html;
                                }

                                var _activePickerContainer = null;
                                var _activePickerHidden = null;

                                function populateFolderPicker(container, hiddenInput, searchInput, excludedSet, filterServerId) {
                                    _activePickerContainer = container;
                                    _activePickerHidden = hiddenInput;
                                    hiddenInput.value = '';

                                    var available = folderData.filter(function(f) {
                                        if (excludedSet.has(f.id)) return false;
                                        if (filterServerId != null && Number(f.server_id) !== Number(filterServerId)) return false;
                                        return true;
                                    });

                                    var html = '<div class="fp-root-option fp-selected" data-id="" onclick="selectPickerItem(this)">📂 Root (không có cha)</div>';

                                    if (filterServerId != null) {
                                        // Single server: flat tree
                                        var tree = buildFolderTree(available);
                                        html += renderPickerTree(tree, 0);
                                    } else {
                                        // Multi-server: group by server
                                        var serverMap = {};
                                        var serverOrder = [];
                                        available.forEach(function(f) {
                                            var sid = f.server_id;
                                            if (!serverMap[sid]) {
                                                serverMap[sid] = { name: f.server_name || ('Server #' + sid), folders: [] };
                                                serverOrder.push(sid);
                                            }
                                            serverMap[sid].folders.push(f);
                                        });
                                        serverOrder.forEach(function(sid) {
                                            var group = serverMap[sid];
                                            html += '<div class="fp-server-header" data-sg="' + sid + '">🖥️ ' + group.name + '</div>';
                                            var tree = buildFolderTree(group.folders);
                                            html += '<div class="fp-server-section" data-sg="' + sid + '">' + renderPickerTree(tree, 0) + '</div>';
                                        });
                                    }

                                    if (available.length === 0) {
                                        html += '<div class="fp-no-results">Không có thư mục nào</div>';
                                    }
                                    container.innerHTML = html;

                                    // Wire search
                                    searchInput.value = '';
                                    searchInput.oninput = function() {
                                        var q = this.value.trim().toLowerCase();
                                        var items = container.querySelectorAll('.fp-item');
                                        var childrenDivs = container.querySelectorAll('.fp-children');
                                        if (!q) {
                                            items.forEach(function(el) { el.style.display = ''; });
                                            childrenDivs.forEach(function(el) { el.classList.add('fp-hidden'); });
                                            container.querySelectorAll('.fp-toggle').forEach(function(t) { t.classList.remove('fp-open'); });
                                            container.querySelectorAll('.fp-server-header').forEach(function(h) { h.style.display = ''; });
                                            container.querySelectorAll('.fp-server-section').forEach(function(s) { s.style.display = ''; });
                                            return;
                                        }
                                        childrenDivs.forEach(function(el) { el.classList.remove('fp-hidden'); });
                                        container.querySelectorAll('.fp-toggle').forEach(function(t) { t.classList.add('fp-open'); });
                                        items.forEach(function(el) {
                                            var name = (el.dataset.name || '').toLowerCase();
                                            var path = (el.dataset.path || '').toLowerCase();
                                            el.style.display = (name.indexOf(q) >= 0 || path.indexOf(q) >= 0) ? '' : 'none';
                                        });
                                        // Hide empty server sections
                                        container.querySelectorAll('.fp-server-section').forEach(function(sec) {
                                            var hasVisible = sec.querySelector('.fp-item:not([style*="display: none"])');
                                            sec.style.display = hasVisible ? '' : 'none';
                                            var header = container.querySelector('.fp-server-header[data-sg="' + sec.dataset.sg + '"]');
                                            if (header) header.style.display = hasVisible ? '' : 'none';
                                        });
                                    };
                                }

                                function selectPickerItem(el) {
                                    if (!_activePickerContainer) return;
                                    // Deselect all in this container
                                    _activePickerContainer.querySelectorAll('.fp-selected').forEach(function(s) { s.classList.remove('fp-selected'); });
                                    el.classList.add('fp-selected');
                                    _activePickerHidden.value = el.dataset.id || '';
                                }

                                function togglePickerNode(toggle) {
                                    var item = toggle.closest('.fp-item');
                                    var children = item.nextElementSibling;
                                    if (children && children.classList.contains('fp-children')) {
                                        children.classList.toggle('fp-hidden');
                                        toggle.classList.toggle('fp-open');
                                    }
                                }

                                function collectDescendants(fid) {
                                    var result = new Set();
                                    result.add(fid);
                                    folderData.forEach(function (f) {
                                        if (f.parent_id === fid) {
                                            collectDescendants(f.id).forEach(function (d) { result.add(d); });
                                        }
                                    });
                                    return result;
                                }

                                function openMoveModal(id, name, path, serverId) {
                                    document.getElementById('moveForm').action = '/folders/move/' + id;
                                    document.getElementById('moveBreadcrumb').textContent = '> ' + path;

                                    var excluded = collectDescendants(id);
                                    populateFolderPicker(
                                        document.getElementById('movePickerContainer'),
                                        document.getElementById('moveParentValue'),
                                        document.getElementById('moveSearch'),
                                        excluded, serverId
                                    );

                                    document.getElementById('moveModal').classList.add('is-open');
                                    setTimeout(function () { document.getElementById('moveSearch').focus(); }, 80);
                                }

                                var STORAGE_KEY = 'folderTreeOpen';
                                var SG_STORAGE_KEY = 'serverGroupOpen';

                                function getOpenSet() {
                                    try { return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')); }
                                    catch (e) { return new Set(); }
                                }

                                function saveOpenSet(set) {
                                    try { localStorage.setItem(STORAGE_KEY, JSON.stringify([...set])); } catch (e) { }
                                }

                                function getSgOpenSet() {
                                    try { return new Set(JSON.parse(localStorage.getItem(SG_STORAGE_KEY) || '[]')); }
                                    catch (e) { return new Set(); }
                                }

                                function saveSgOpenSet(set) {
                                    try { localStorage.setItem(SG_STORAGE_KEY, JSON.stringify([...set])); } catch (e) { }
                                }

                                function toggleServerGroup(label) {
                                    var serverId = label.dataset.serverId;
                                    var content = document.querySelector('.server-group-content[data-sg-server="' + serverId + '"]');
                                    var chevron = label.querySelector('.sg-chevron');
                                    if (!content) return;
                                    var isCollapsed = content.classList.toggle('sg-collapsed');
                                    if (chevron) chevron.classList.toggle('sg-open', !isCollapsed);
                                    var sgSet = getSgOpenSet();
                                    if (isCollapsed) sgSet.delete(serverId);
                                    else sgSet.add(serverId);
                                    saveSgOpenSet(sgSet);
                                }

                                function toggleNode(btn) {
                                    var li = btn.closest('.folder-node');
                                    var childList = li.querySelector('.children-list');
                                    if (!childList) return;
                                    var folderId = btn.dataset.folderId;
                                    var collapsed = childList.classList.toggle('collapsed');
                                    btn.classList.toggle('open', !collapsed);
                                    var openSet = getOpenSet();
                                    if (collapsed) openSet.delete(folderId);
                                    else openSet.add(folderId);
                                    saveOpenSet(openSet);
                                }

                                function expandAll() {
                                    // Expand server groups
                                    document.querySelectorAll('.server-group-content').forEach(function (el) {
                                        el.classList.remove('sg-collapsed');
                                    });
                                    document.querySelectorAll('.sg-chevron').forEach(function (c) { c.classList.add('sg-open'); });
                                    var sgSet = new Set();
                                    document.querySelectorAll('.server-group-content').forEach(function (el) {
                                        sgSet.add(el.dataset.sgServer);
                                    });
                                    saveSgOpenSet(sgSet);

                                    // Expand folder nodes
                                    var openSet = getOpenSet();
                                    document.querySelectorAll('.children-list').forEach(function (ul) {
                                        ul.classList.remove('collapsed');
                                        var pid = ul.dataset.parentId;
                                        if (pid) openSet.add(pid);
                                    });
                                    document.querySelectorAll('.toggle-btn').forEach(function (b) { b.classList.add('open'); });
                                    saveOpenSet(openSet);
                                }

                                function collapseAll() {
                                    // Collapse server groups
                                    document.querySelectorAll('.server-group-content').forEach(function (el) {
                                        el.classList.add('sg-collapsed');
                                    });
                                    document.querySelectorAll('.sg-chevron').forEach(function (c) { c.classList.remove('sg-open'); });
                                    saveSgOpenSet(new Set());

                                    // Collapse folder nodes
                                    document.querySelectorAll('.children-list').forEach(function (ul) {
                                        ul.classList.add('collapsed');
                                    });
                                    document.querySelectorAll('.toggle-btn').forEach(function (b) { b.classList.remove('open'); });
                                    saveOpenSet(new Set());
                                }

                                // Restore saved states on load
                                (function restoreTree() {
                                    // Restore server groups
                                    var sgSet = getSgOpenSet();
                                    sgSet.forEach(function (serverId) {
                                        var content = document.querySelector('.server-group-content[data-sg-server="' + serverId + '"]');
                                        if (content) content.classList.remove('sg-collapsed');
                                        var label = document.querySelector('.server-group-label[data-server-id="' + serverId + '"]');
                                        if (label) {
                                            var chevron = label.querySelector('.sg-chevron');
                                            if (chevron) chevron.classList.add('sg-open');
                                        }
                                    });

                                    // Restore folder nodes
                                    var openSet = getOpenSet();
                                    openSet.forEach(function (folderId) {
                                        var btn = document.querySelector('.toggle-btn[data-folder-id="' + folderId + '"]');
                                        if (!btn) return;
                                        var li = btn.closest('.folder-node');
                                        var childList = li && li.querySelector('.children-list');
                                        if (childList) {
                                            childList.classList.remove('collapsed');
                                            btn.classList.add('open');
                                        }
                                    });
                                })();

                                (function () {
                                    var p = new URLSearchParams(location.search);
                                    if (p.has('error') || p.has('success')) history.replaceState(null, '', location.pathname);
                                })();

                                // ── Bulk Move ──────────────────────────────────────────────
                                function getCheckedFolders() {
                                    return [...document.querySelectorAll('.folder-check:checked')].map(function(c) {
                                        return { id: +c.value, serverId: +c.dataset.serverId };
                                    });
                                }

                                function updateBulkFolderToolbar() {
                                    var checked = getCheckedFolders();
                                    var toolbar = document.getElementById('bulkFolderToolbar');
                                    if (!toolbar) return;
                                    if (checked.length > 0) {
                                        toolbar.style.display = 'flex';
                                        document.getElementById('bulkFolderCount').textContent = checked.length + ' đã chọn';
                                    } else {
                                        toolbar.style.display = 'none';
                                    }
                                }

                                function clearFolderSelection() {
                                    document.querySelectorAll('.folder-check').forEach(function(c) { c.checked = false; });
                                    updateBulkFolderToolbar();
                                }

                                function openBulkMoveModal() {
                                    var checked = getCheckedFolders();
                                    if (!checked.length) return;

                                    var selectedIds = new Set(checked.map(function(c) { return c.id; }));

                                    var excluded = new Set();
                                    selectedIds.forEach(function(fid) {
                                        collectDescendants(fid).forEach(function(d) { excluded.add(d); });
                                    });

                                    // Summary
                                    var names = checked.map(function(c) {
                                        var f = folderData.find(function(fd) { return fd.id === c.id; });
                                        return f ? f.name : '#' + c.id;
                                    });
                                    document.getElementById('bulkMoveSummary').textContent = '📋 ' + names.join(', ');

                                    // Populate target picker — exclude selected and their descendants
                                    populateFolderPicker(
                                        document.getElementById('bulkMovePickerContainer'),
                                        document.getElementById('bulkMoveTargetValue'),
                                        document.getElementById('bulkMoveSearch'),
                                        excluded, null
                                    );

                                    document.getElementById('bulkMoveModal').classList.add('is-open');
                                    setTimeout(function() { document.getElementById('bulkMoveSearch').focus(); }, 80);
                                }

                                async function submitBulkMove() {
                                    var checked = getCheckedFolders();
                                    if (!checked.length) return;
                                    var btn = document.getElementById('bulkMoveSubmitBtn');
                                    var origText = btn.textContent;
                                    btn.disabled = true;
                                    btn.textContent = '⏳ Đang xử lý...';

                                    var targetId = document.getElementById('bulkMoveTargetValue').value;

                                    try {
                                        var res = await fetch('/folders/bulk-move', {
                                            method: 'POST',
                                            headers: { 'Content-Type': 'application/json' },
                                            body: JSON.stringify({
                                                folder_ids: checked.map(function(c) { return c.id; }),
                                                new_parent_id: targetId === '' ? null : parseInt(targetId)
                                            })
                                        });
                                        var data = await res.json();
                                        if (data.success) {
                                            var msg = '✅ Đã di chuyển ' + data.moved + ' thư mục';
                                            if (data.skipped > 0) msg += '\n⏩ Bỏ qua ' + data.skipped;
                                            if (data.errors && data.errors.length > 0) msg += '\n⚠️ ' + data.errors.join(', ');
                                            alert(msg);
                                            location.reload();
                                        } else {
                                            alert('❌ ' + (data.error || 'Lỗi không xác định'));
                                        }
                                    } catch(e) {
                                        alert('❌ Lỗi kết nối');
                                    }
                                    btn.disabled = false;
                                    btn.textContent = origText;
                                }

                                // Double-click confirm for folder delete
                                document.addEventListener('click', function (e) {
                                    var btn = e.target.closest('.folder-delete-btn');
                                    if (!btn) return;
                                    if (btn.dataset.confirm !== '1') {
                                        btn.dataset.confirm = '1';
                                        var orig = btn.innerHTML;
                                        btn.innerHTML = '✓ <span>Xác nhận?</span>';
                                        btn.style.color = '#f87171';
                                        var t = setTimeout(function () {
                                            btn.dataset.confirm = '';
                                            btn.innerHTML = orig;
                                            btn.style.color = '';
                                        }, 3000);
                                        btn._resetTimer = t;
                                        return;
                                    }
                                    // Confirmed — submit delete
                                    var id = btn.dataset.id;
                                    var form = document.createElement('form');
                                    form.method = 'POST';
                                    form.action = '/folders/delete/' + id;
                                    document.body.appendChild(form);
                                    form.submit();
                                });
                            </script>

                            <%- include('footer') %>