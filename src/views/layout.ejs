<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Video Manager' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="app-layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <span class="logo-icon">🎬</span>
          <span class="logo-text">VideoManager</span>
        </div>
        <button class="sidebar-toggle" id="sidebarToggle">☰</button>
      </div>

      <div class="user-info">
        <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <div class="user-details">
          <div class="user-name"><%= user.username %></div>
          <div class="user-role badge-<%= user.role %>"><%= user.role === 'administrator' ? '👑 Admin' : '📤 Uploader' %></div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= activePage === 'dashboard' ? 'active' : '' %>">
          <span class="nav-icon">📊</span>
          <span class="nav-label">Dashboard</span>
        </a>
        <a href="/videos/upload" class="nav-item <%= activePage === 'upload' ? 'active' : '' %>">
          <span class="nav-icon">⬆️</span>
          <span class="nav-label">Upload Video</span>
        </a>
        <a href="/videos" class="nav-item <%= activePage === 'videos' ? 'active' : '' %>">
          <span class="nav-icon">🎥</span>
          <span class="nav-label">Quản lí Video</span>
        </a>
        <a href="/folders" class="nav-item <%= activePage === 'folders' ? 'active' : '' %>">
          <span class="nav-icon">📁</span>
          <span class="nav-label">Thư mục</span>
        </a>
        <% if (user.role === 'administrator') { %>
        <a href="/servers" class="nav-item <%= activePage === 'servers' ? 'active' : '' %>">
          <span class="nav-icon">🖥️</span>
          <span class="nav-label">Servers</span>
        </a>
        <a href="/users" class="nav-item <%= activePage === 'users' ? 'active' : '' %>">
          <span class="nav-icon">👥</span>
          <span class="nav-label">Users</span>
        </a>
        <% } %>
        <a href="/settings" class="nav-item <%= activePage === 'settings' ? 'active' : '' %>">
          <span class="nav-icon">⚙️</span>
          <span class="nav-label">Cài đặt</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <a href="/logout" class="nav-item logout-btn">
          <span class="nav-icon">🚪</span>
          <span class="nav-label">Đăng xuất</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <div class="page-wrapper">
        <%- body %>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
