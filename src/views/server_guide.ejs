                                onclick="copyCode(this)">Copy</button></div>
                        <pre>#!/bin/bash
set -e

APP_DIR="/var/www/manager_video"
APP_NAME="manager_video"

echo "[$(date)] 🚀 Bắt đầu deploy..."

cd $APP_DIR

# Pull code mới
