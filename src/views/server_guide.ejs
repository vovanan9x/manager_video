<%- include('header') %>

    <style>
        .guide-layout {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 0;
            min-height: calc(100vh - 120px);
        }

        .guide-sidebar {
            background: var(--bg-card);
            border-right: 1px solid var(--border);
            padding: 1.5rem 0;
            position: sticky;
            top: 0;
            height: fit-content;
            border-radius: var(--radius) 0 0 var(--radius);
        }

        .guide-sidebar a {
            display: block;
            padding: 0.5rem 1.25rem;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.85rem;
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }

        .guide-sidebar a:hover,
        .guide-sidebar a.active {
            color: var(--accent);
            border-left-color: var(--accent);
            background: rgba(99, 102, 241, 0.06);
        }

        .guide-sidebar .section-title {
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: 0.75rem 1.25rem 0.25rem;
            margin-top: 0.5rem;
        }

        .guide-content {
            padding: 0 2rem 3rem;
        }

        .guide-section {
            margin-bottom: 3rem;
            scroll-margin-top: 1rem;
        }

        .guide-section h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
        }

        .guide-section h3 {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text);
            margin: 1.5rem 0 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .guide-section p,
        .guide-section li {
            font-size: 0.88rem;
            color: var(--text-muted);
            line-height: 1.7;
        }

        .guide-section ul,
        .guide-section ol {
            padding-left: 1.4rem;
            margin: 0.5rem 0 1rem;
        }

        .guide-section li {
            margin-bottom: 0.3rem;
        }

        .step-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            margin-bottom: 1.25rem;
            overflow: hidden;
        }

        .step-header {
            padding: 0.85rem 1.25rem;
            background: rgba(0, 0, 0, 0.15);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .step-num {
            background: var(--accent);
            color: #fff;
            font-size: 0.72rem;
            font-weight: 700;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .step-title {
            font-weight: 600;
            font-size: 0.92rem;
            color: var(--text);
        }

        .step-body {
            padding: 1.1rem 1.25rem;
        }

        .code-block {
            background: #0f172a;
            border-radius: 8px;
            overflow: hidden;
            margin: 0.5rem 0;
            position: relative;
        }

        .code-block-header {
            background: rgba(255, 255, 255, 0.05);
            padding: 0.4rem 0.85rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .code-block pre {
            margin: 0;
            padding: 1rem;
            font-size: 0.82rem;
            overflow-x: auto;
            color: #e2e8f0;
            line-height: 1.6;
        }

        .copy-btn {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: var(--text-muted);
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.15s;
        }

        .copy-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            color: var(--text);
        }

        .alert-info {
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.3);
            border-radius: 8px;
            padding: 0.85rem 1.1rem;
            font-size: 0.85rem;
            color: var(--text);
            margin: 0.75rem 0;
        }

        .alert-warn {
            background: rgba(251, 191, 36, 0.1);
            border: 1px solid rgba(251, 191, 36, 0.3);
            border-radius: 8px;
            padding: 0.85rem 1.1rem;
            font-size: 0.85rem;
            color: var(--text);
            margin: 0.75rem 0;
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 8px;
            padding: 0.85rem 1.1rem;
            font-size: 0.85rem;
            color: var(--text);
            margin: 0.75rem 0;
        }

        .field-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.84rem;
            margin: 0.5rem 0 1rem;
        }

        .field-table th {
            text-align: left;
            padding: 0.4rem 0.75rem;
            background: rgba(0, 0, 0, 0.15);
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
        }

        .field-table td {
            padding: 0.45rem 0.75rem;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
        }

        .field-table tr:last-child td {
            border-bottom: none;
        }

        .field-name {
            font-family: monospace;
            color: var(--accent);
            font-size: 0.85rem;
        }

        .badge-req {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-size: 0.7rem;
            padding: 0.1rem 0.4rem;
            border-radius: 4px;
            font-weight: 600;
        }

        .badge-opt {
            background: rgba(148, 163, 184, 0.12);
            color: var(--text-muted);
            font-size: 0.7rem;
            padding: 0.1rem 0.4rem;
            border-radius: 4px;
        }

        .type-tag {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1px 6px;
            font-family: monospace;
            font-size: 0.78rem;
            color: #f59e0b;
        }

        .server-type-tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 0;
        }

        .server-type-tab {
            padding: 0.5rem 1rem;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.15s;
            margin-bottom: -1px;
        }

        .server-type-tab:hover {
            color: var(--text);
        }

        .server-type-tab.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

        code {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1px 6px;
            font-family: monospace;
            font-size: 0.85em;
            color: #f59e0b;
        }
    </style>

    <div class="page-header">
        <div>
            <h1 class="page-title">🖥️ Hướng dẫn cấu hình Server</h1>
            <p class="text-muted" style="margin-top:0.25rem">Hướng dẫn chi tiết cách thiết lập và kiểm tra kết nối cho
                từng loại server lưu trữ</p>
        </div>
        <% if (user.role==='administrator' ) { %>
            <a href="/servers" class="btn btn-primary">⚙️ Quản lí Servers</a>
            <% } %>
    </div>

    <div class="guide-layout">
        <!-- Sidebar -->
        <div class="guide-sidebar">
            <div class="section-title">Tổng quan</div>
            <a href="#overview">🗺️ Quy trình chung</a>
            <a href="#fields">📋 Các trường cấu hình</a>

            <div class="section-title">Loại Server</div>
            <a href="#sftp-password">🔐 SFTP (Password)</a>
            <a href="#sftp-key">🔑 SFTP (SSH Key)</a>

            <div class="section-title">Sau khi thêm</div>
            <a href="#test">✅ Test kết nối</a>
            <a href="#folder">📁 Tạo thư mục</a>
            <a href="#upload">⬆️ Upload video</a>
            <a href="#nginx">🌐 Cấu hình Nginx</a>
            <a href="#troubleshoot">🔧 Xử lý sự cố</a>

            <div class="section-title">CI/CD</div>
            <a href="#deploy">🚀 Auto Deploy từ GitHub</a>
        </div>

        <!-- Content -->
        <div class="guide-content">

            <!-- OVERVIEW -->
            <div class="guide-section" id="overview">
                <h2>🗺️ Quy trình chung sau khi thêm server</h2>
                <p>Sau khi thêm một server mới vào hệ thống, cần thực hiện các bước sau theo thứ tự:</p>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">1</div>
                        <span class="step-title">Thêm server tại trang Servers</span>
                    </div>
                    <div class="step-body">
                        <p>Vào <a href="/servers" style="color:var(--accent)">⚙️ Servers</a> → nhấn <strong>Thêm
                                Server</strong> → điền thông tin cấu hình → lưu.</p>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">2</div>
                        <span class="step-title">Test kết nối</span>
                    </div>
                    <div class="step-body">
                        <p>Tại trang Servers, nhấn nút <strong>🔌 Test</strong> trên server vừa thêm. Đèn xanh = kết nối
                            thành công.</p>
                        <div class="alert-warn">⚠️ Nếu test thất bại, kiểm tra lại host, port, username, password/SSH
                            key và đảm bảo IP server không bị firewall chặn.</div>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">3</div>
                        <span class="step-title">Tạo thư mục gốc</span>
                    </div>
                    <div class="step-body">
                        <p>Vào <a href="/folders" style="color:var(--accent)">📁 Thư mục</a> → nhấn <strong>➕ Tạo thư
                                mục gốc</strong> → chọn server vừa thêm → đặt tên thư mục.</p>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">4</div>
                        <span class="step-title">Upload video đầu tiên</span>
                    </div>
                    <div class="step-body">
                        <p>Vào <a href="/videos/upload" style="color:var(--accent)">⬆️ Upload Video</a> → chọn server và
                            thư mục vừa tạo → upload thử một file nhỏ để xác nhận pipeline hoạt động.</p>
                    </div>
                </div>
            </div>

            <!-- FIELDS -->
            <div class="guide-section" id="fields">
                <h2>📋 Các trường cấu hình</h2>
                <p>Giải thích chi tiết từng trường khi thêm/sửa server:</p>

                <table class="field-table">
                    <tr>
                        <th>Trường</th>
                        <th>Bắt buộc</th>
                        <th>Loại</th>
                        <th>Mô tả</th>
                    </tr>
                    <tr>
                        <td class="field-name">name</td>
                        <td><span class="badge-req">✓ Bắt buộc</span></td>
                        <td><span class="type-tag">text</span></td>
                        <td>Tên hiển thị của server trong hệ thống. Ví dụ: <code>Hetzner VPS 1</code></td>
                    </tr>
                    <tr>
                        <td class="field-name">type</td>
                        <td><span class="badge-req">✓ Bắt buộc</span></td>
                        <td><span class="type-tag">select</span></td>
                        <td><code>sftp</code> · <code>http</code> — loại kết nối</td>
                    </tr>
                    <tr>
                        <td class="field-name">host</td>
                        <td><span class="badge-opt">SFTP/HTTP</span></td>
                        <td><span class="type-tag">text</span></td>
                        <td>Địa chỉ IP hoặc domain của server. Ví dụ: <code>65.21.100.200</code></td>
                    </tr>
                    <tr>
                        <td class="field-name">port</td>
                        <td><span class="badge-opt">Tuỳ chọn</span></td>
                        <td><span class="type-tag">number</span></td>
                        <td>Port SFTP. Mặc định <code>22</code>.</td>
                    </tr>
                    <tr>
                        <td class="field-name">username</td>
                        <td><span class="badge-opt">SFTP</span></td>
                        <td><span class="type-tag">text</span></td>
                        <td>Tên đăng nhập SFTP. Ví dụ: <code>root</code> hoặc <code>deploy</code></td>
                    </tr>
                    <tr>
                        <td class="field-name">password</td>
                        <td><span class="badge-opt">Tuỳ chọn</span></td>
                        <td><span class="type-tag">password</span></td>
                        <td>Mật khẩu SFTP. Nếu dùng SSH key thì để trống hoặc nhập passphrase của key</td>
                    </tr>
                    <tr>
                        <td class="field-name">root_path</td>
                        <td><span class="badge-req">✓ Bắt buộc</span></td>
                        <td><span class="type-tag">text</span></td>
                        <td>Đường dẫn gốc để lưu video trên server. Ví dụ: SFTP: <code>/home/videos</code>
                        </td>
                    </tr>
                    <tr>
                        <td class="field-name">base_url</td>
                        <td><span class="badge-opt">Tuỳ chọn</span></td>
                        <td><span class="type-tag">url</span></td>
                        <td>URL công khai để stream video. Ví dụ: <code>https://cdn.example.com</code>. Hệ thống dùng để
                            tạo link xem video</td>
                    </tr>
                    <tr>
                        <td class="field-name">private_key</td>
                        <td><span class="badge-opt">Tuỳ chọn</span></td>
                        <td><span class="type-tag">textarea</span></td>
                        <td>Nội dung SSH private key (dán toàn bộ từ <code>-----BEGIN...</code> đến
                            <code>-----END...</code>). Ưu tiên hơn password
                        </td>
                    </tr>
                </table>
            </div>


            <!-- SFTP PASSWORD -->
            <div class="guide-section" id="sftp-password">
                <h2>🔐 SFTP với Password</h2>
                <p>Kết nối đến server Linux/VPS qua SFTP bằng username + password. Phù hợp với Hetzner VPS, DigitalOcean
                    Droplet, hoặc bất kỳ server SSH nào.</p>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">1</div>
                        <span class="step-title">Thông tin cần chuẩn bị</span>
                    </div>
                    <div class="step-body">
                        <ul>
                            <li>IP hoặc domain của server (ví dụ: <code>65.21.xxx.xxx</code>)</li>
                            <li>Tên user SFTP (thường là <code>root</code> hoặc user riêng)</li>
                            <li>Mật khẩu SSH</li>
                            <li>Đường dẫn thư mục lưu video trên server (ví dụ: <code>/var/www/videos</code>)</li>
                            <li>URL công khai nếu muốn stream trực tiếp (ví dụ: <code>https://cdn.mysite.com</code>)
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">2</div>
                        <span class="step-title">Cấu hình trong hệ thống</span>
                    </div>
                    <div class="step-body">
                        <table class="field-table">
                            <tr>
                                <th>Trường</th>
                                <th>Giá trị ví dụ</th>
                            </tr>
                            <tr>
                                <td class="field-name">type</td>
                                <td><code>sftp</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">host</td>
                                <td><code>65.21.100.200</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">port</td>
                                <td><code>22</code> (mặc định)</td>
                            </tr>
                            <tr>
                                <td class="field-name">username</td>
                                <td><code>root</code> hoặc <code>deploy</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">password</td>
                                <td><code>your_ssh_password</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">root_path</td>
                                <td><code>/var/www/videos</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">base_url</td>
                                <td><code>https://cdn.mysite.com</code></td>
                            </tr>
                        </table>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">3</div>
                        <span class="step-title">Tạo thư mục trên server (nếu chưa có)</span>
                    </div>
                    <div class="step-body">
                        <div class="code-block">
                            <div class="code-block-header"><span>SSH vào server</span><button class="copy-btn"
                                    onclick="copyCode(this)">Copy</button></div>
                            <pre>ssh root@65.21.100.200
mkdir -p /var/www/videos
chmod 755 /var/www/videos</pre>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SFTP KEY -->
            <div class="guide-section" id="sftp-key">
                <h2>🔑 SFTP với SSH Key</h2>
                <p>Kết nối SFTP bằng SSH key (an toàn hơn password). Khuyến nghị cho môi trường production.</p>

                <div class="alert-success">
                    ✅ SSH key an toàn hơn password vì không bị brute-force. Luôn ưu tiên dùng SSH key cho server
                    production.
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">1</div>
                        <span class="step-title">Tạo SSH key pair (nếu chưa có)</span>
                    </div>
                    <div class="step-body">
                        <div class="code-block">
                            <div class="code-block-header"><span>Tạo key mới</span><button class="copy-btn"
                                    onclick="copyCode(this)">Copy</button></div>
                            <pre>ssh-keygen -t ed25519 -C "videomanager" -f ~/.ssh/videomanager_key
# Nhập passphrase nếu muốn bảo vệ key (để trống nếu không cần)</pre>
                        </div>
                        <p style="margin-top:.75rem">Kết quả: 2 file được tạo:</p>
                        <ul>
                            <li><code>~/.ssh/videomanager_key</code> — <strong>Private key</strong> (giữ bí mật, dán vào
                                hệ thống)</li>
                            <li><code>~/.ssh/videomanager_key.pub</code> — <strong>Public key</strong> (upload lên
                                server)</li>
                        </ul>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">2</div>
                        <span class="step-title">Cài public key lên server</span>
                    </div>
                    <div class="step-body">
                        <div class="code-block">
                            <div class="code-block-header"><span>Từ máy local</span><button class="copy-btn"
                                    onclick="copyCode(this)">Copy</button></div>
                            <pre>ssh-copy-id -i ~/.ssh/videomanager_key.pub root@65.21.100.200
# Hoặc thủ công:
cat ~/.ssh/videomanager_key.pub | ssh root@65.21.100.200 "cat >> ~/.ssh/authorized_keys"</pre>
                        </div>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">3</div>
                        <span class="step-title">Lấy nội dung private key</span>
                    </div>
                    <div class="step-body">
                        <div class="code-block">
                            <div class="code-block-header"><span>Đọc private key</span><button class="copy-btn"
                                    onclick="copyCode(this)">Copy</button></div>
                            <pre>cat ~/.ssh/videomanager_key</pre>
                        </div>
                        <p>Copy toàn bộ nội dung (từ <code>-----BEGIN OPENSSH PRIVATE KEY-----</code> đến
                            <code>-----END OPENSSH PRIVATE KEY-----</code>) và dán vào trường <strong>Private
                                Key</strong> trong form thêm server.
                        </p>
                    </div>
                </div>

                <div class="step-card">
                    <div class="step-header">
                        <div class="step-num">4</div>
                        <span class="step-title">Cấu hình trong hệ thống</span>
                    </div>
                    <div class="step-body">
                        <table class="field-table">
                            <tr>
                                <th>Trường</th>
                                <th>Giá trị</th>
                            </tr>
                            <tr>
                                <td class="field-name">type</td>
                                <td><code>sftp</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">host</td>
                                <td><code>65.21.100.200</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">port</td>
                                <td><code>22</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">username</td>
                                <td><code>root</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">password</td>
                                <td>Passphrase của key (để trống nếu key không có passphrase)</td>
                            </tr>
                            <tr>
                                <td class="field-name">root_path</td>
                                <td><code>/var/www/videos</code></td>
                            </tr>
                            <tr>
                                <td class="field-name">private_key</td>
                                <td>Dán toàn bộ nội dung private key</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <!-- TEST -->
            <div class="guide-section" id="test">
                <h2>✅ Test kết nối</h2>
