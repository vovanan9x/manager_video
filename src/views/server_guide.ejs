            <!-- CÁCH 1: WEBHOOK -->
            <h3 style="margin:2rem 0 .75rem">① Cấu hình tự động qua GitHub Webhook</h3>

            <div class="step-card">
                <div class="step-header">
                    <div class="step-num">5a</div>
                    <span class="step-title">Tạo Webhook receiver trong ứng dụng</span>
                </div>
                <div class="step-body">
                    <p>Thêm route này vào <code>src/app.js</code> (hoặc file route riêng):</p>
                    <div class="code-block">
                        <div class="code-block-header"><span>src/app.js — thêm route webhook</span><button
                                class="copy-btn" onclick="copyCode(this)">Copy</button></div>
                        <pre>const crypto = require('crypto');
const { exec } = require('child_process');

// GitHub Webhook — không cần xác thực session
app.post('/deploy/webhook', express.raw({ type: 'application/json' }), (req, res) => {
    const secret = process.env.WEBHOOK_SECRET || '';
    const sig    = req.headers['x-hub-signature-256'] || '';

    // Xác minh chữ ký từ GitHub
    if (secret) {
        const hmac     = crypto.createHmac('sha256', secret);
        const expected = 'sha256=' + hmac.update(req.body).digest('hex');
        if (sig !== expected) {
            return res.status(403).json({ error: 'Invalid signature' });
        }
    }

    const payload = JSON.parse(req.body);
    if (payload.ref !== 'refs/heads/main') {
        return res.json({ message: 'Not main branch, skipped' });
    }

    console.log('[Webhook] Push tới main, bắt đầu deploy...');
    res.json({ message: 'Deploy started' });

    // Chạy deploy script
    exec('bash /var/www/deploy.sh >> /var/log/deploy.log 2>&1', (err) => {
        if (err) console.error('[Webhook] Deploy error:', err.message);
        else     console.log('[Webhook] Deploy xong!');
    });
});</pre>
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Thêm vào .env trên server</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre>WEBHOOK_SECRET=your_random_secret_here</pre>
                    </div>
                    <div class="alert-warn">
                        ⚠️ Nếu server dùng UFW firewall, mở port của app (mặc định 3000):
                        <br><code>sudo ufw allow 3000/tcp</code><br>
                        Sau đó thiết lập Nginx reverse proxy để expose qua port 80/443.
                    </div>
                </div>
            </div>

            <div class="step-card">
                <div class="step-header">
                    <div class="step-num">5b</div>
                    <span class="step-title">Cấu hình Webhook trên GitHub</span>
                </div>
                <div class="step-body">
                    <ol>
                        <li>Vào GitHub repo → <strong>Settings</strong> → <strong>Webhooks</strong> → <strong>Add
                                webhook</strong></li>
                        <li><strong>Payload URL:</strong> <code>https://your-server.com/deploy/webhook</code></li>
                        <li><strong>Content type:</strong> <code>application/json</code></li>
                        <li><strong>Secret:</strong> Giá trị <code>WEBHOOK_SECRET</code> giống trong <code>.env</code>
                        </li>
                        <li>Chọn <strong>Just the push event</strong></li>
                        <li>Nhấn <strong>Add webhook</strong></li>
                    </ol>
                    <div class="alert-success">
                        ✅ Từ đây mỗi lần <code>git push origin main</code> từ máy local, server sẽ tự động pull và
                        reload trong vài giây.
                    </div>
                </div>
            </div>

            <!-- CÁCH 2: CRON -->
            <h3 style="margin:2rem 0 .75rem">② Cấu hình tự động qua Cron Job (đơn giản hơn)</h3>

            <div class="step-card">
                <div class="step-header">
                    <div class="step-num">5c</div>
                    <span class="step-title">Script kiểm tra và pull khi có commit mới</span>
                </div>
                <div class="step-body">
                    <div class="code-block">
                        <div class="code-block-header"><span>Tạo /var/www/check_deploy.sh</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre>#!/bin/bash
APP_DIR="/var/www/manager_video"

cd $APP_DIR
git fetch origin main --quiet

LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main)

if [ "$LOCAL" != "$REMOTE" ]; then
    echo "[$(date)] Có commit mới, bắt đầu deploy..."
    bash /var/www/deploy.sh
fi</pre>
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Thêm vào crontab (kiểm tra mỗi 2 phút)</span><button
                                class="copy-btn" onclick="copyCode(this)">Copy</button></div>
                        <pre>crontab -e
# Thêm dòng này:
*/2 * * * * bash /var/www/check_deploy.sh >> /var/log/deploy.log 2>&1</pre>
                    </div>
                    <div class="alert-warn">
                        ⚠️ Cron cần server có quyền đọc repo GitHub. Nếu repo private, thêm GitHub Deploy Key (xem bước
                        dưới).
                    </div>
                </div>
            </div>

            <!-- PRIVATE REPO -->
            <div class="step-card">
                <div class="step-header">
                    <div class="step-num">6</div>
                    <span class="step-title">Xử lý Private Repository (Deploy Key)</span>
                </div>
                <div class="step-body">
                    <p>Nếu repo GitHub của bạn là <strong>private</strong>, server cần có quyền đọc qua SSH Deploy Key:
                    </p>
                    <div class="code-block">
                        <div class="code-block-header"><span>Trên server — tạo deploy key</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre>ssh-keygen -t ed25519 -C "deploy@server" -f ~/.ssh/github_deploy -N ""
cat ~/.ssh/github_deploy.pub   # Copy nội dung này</pre>
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Thêm vào GitHub</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre># GitHub Repo → Settings → Deploy keys → Add deploy key
# Dán nội dung ~/.ssh/github_deploy.pub, chọn "Allow write access" nếu cần</pre>
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Cấu hình SSH để dùng deploy key</span><button
                                class="copy-btn" onclick="copyCode(this)">Copy</button></div>
                        <pre>nano ~/.ssh/config
# Thêm:
Host github.com
    IdentityFile ~/.ssh/github_deploy
    StrictHostKeyChecking no</pre>
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Thay remote URL sang SSH</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre>cd /var/www/manager_video
git remote set-url origin git@github.com:YOUR_USER/manager_video.git</pre>
                    </div>
                </div>
            </div>

            <!-- QUY TRÌNH DAILY -->
            <div class="step-card">
                <div class="step-header">
                    <span class="step-title">🔄 Quy trình hàng ngày sau khi thiết lập xong</span>
                </div>
                <div class="step-body">
                    <div class="code-block">
                        <div class="code-block-header"><span>Máy local (Windows)</span><button class="copy-btn"
                                onclick="copyCode(this)">Copy</button></div>
                        <pre># Sửa code bất kỳ file nào...
git add .
git commit -m "fix: mô tả thay đổi"
git push origin main
# → Server tự động pull và reload trong vài giây</pre>
                    </div>
                    <div class="alert-success">
                        ✅ Không cần SSH vào server, không cần restart thủ công. Chỉ cần <code>git push</code> là xong!
                    </div>
                    <div class="code-block">
                        <div class="code-block-header"><span>Theo dõi log deploy trên server</span><button
                                class="copy-btn" onclick="copyCode(this)">Copy</button></div>
                        <pre>tail -f /var/log/deploy.log
# Hoặc xem log PM2:
pm2 logs manager_video --lines 50</pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function copyCode(btn) {
            const pre = btn.closest('.code-block').querySelector('pre');
            navigator.clipboard.writeText(pre.textContent.trim()).then(() => {
                btn.textContent = '✓ Copied';
                setTimeout(() => btn.textContent = 'Copy', 2000);
            });
        }

        // Highlight active sidebar link on scroll
        const sections = document.querySelectorAll('.guide-section');
        const sidebarLinks = document.querySelectorAll('.guide-sidebar a');
        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(s => { if (window.scrollY >= s.offsetTop - 80) current = s.id; });
            sidebarLinks.forEach(a => { a.classList.toggle('active', a.getAttribute('href') === '#' + current); });
        }, { passive: true });
    </script>

