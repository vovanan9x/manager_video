                    <div class="step-header">
                        <div class="step-num">2</div>
                        <span class="step-title">Cấu hình Nginx serve thư mục video (HTTP)</span>
                    </div>
                    <div class="step-body">
                        <p>Tạo file cấu hình Nginx mới:</p>
                        <div class="code-block">
                            <div class="code-block-header"><span>Tạo file config</span><button class="copy-btn"
                                    onclick="copyCode(this)">Copy</button></div>
                            <pre>sudo nano /etc/nginx/sites-available/videos</pre>
                        </div>
                        <p style="margin-top:.75rem">Nội dung file cấu hình:</p>
                        <div class="code-block">
                            <div class="code-block-header"><span>/etc/nginx/sites-available/videos</span><button
                                    class="copy-btn" onclick="copyCode(this)">Copy</button></div>
                            <pre>server {
    listen 80;
    server_name cdn.mysite.com;  # Domain hoặc IP của server

    # Thư mục chứa video (= root_path trong Video Manager)
    root /var/www/videos;

    location / {
        # Cho phép truy cập trực tiếp file
        autoindex off;             # Tắt list thư mục (bảo mật)

        # CORS — cho phép embed video từ domain khác
        add_header Access-Control-Allow-Origin  "*";
        add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS";

        # Cache tốt cho video tĩnh
        add_header Cache-Control "public, max-age=604800, immutable";

        # Hỗ trợ HTTP Range (cần thiết cho video seek)
        add_header Accept-Ranges bytes;
    }

    # Tăng giới hạn kích thước response
    client_max_body_size 0;

    # Tắt access log để giảm I/O (tùy chọn)
    access_log off;
}</pre>
                        </div>
