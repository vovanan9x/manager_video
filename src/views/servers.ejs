<%- include('header', { pageTitle: 'Servers - VideoManager' }) %>

<div class="page-header">
    <div style="display:flex;align-items:center;gap:.75rem">
        <h1 class="page-title">🖥️ Quản lí Servers</h1>
        <button class="btn btn-secondary btn-xs" onclick="loadAllDiskStats()" id="refreshStatsBtn" style="margin-top:.15rem">🔄 Cập nhật Disk</button>
    </div>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<div class="content-grid-2">
    <!-- Add form -->
    <div class="card">
        <div class="card-header"><h3 class="card-title">➕ Thêm Server</h3></div>
        <div class="card-body">
            <form method="POST" action="/servers/add">
                <div class="form-group">
                    <label class="form-label">Tên server *</label>
                    <input type="text" name="name" class="form-control" placeholder="VD: Storage Server #1" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Loại kết nối *</label>
                    <select name="type" id="serverType" class="form-control" onchange="toggleServerFields(this.value)">
                        <option value="sftp">🔐 SFTP</option>
                        <option value="http">🌐 HTTP Upload</option>
                    </select>
                </div>
                <div id="remoteFields" style="display:none">
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Host</label>
                            <input type="text" name="host" class="form-control" placeholder="192.168.1.100">
                        </div>
                        <div class="form-group" style="max-width:110px">
                            <label class="form-label">Port</label>
                            <input type="number" name="port" class="form-control" placeholder="22">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Username</label>
                            <input type="text" name="username" class="form-control">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Password <span class="text-muted" style="text-transform:none;font-weight:400;font-size:.7rem">(hoặc passphrase)</span></label>
                            <input type="password" name="password" class="form-control">
                        </div>
                    </div>
                    <div class="form-group" id="sftpKeyGroup" style="display:none">
                        <label class="form-label">🔑 SSH Private Key</label>
                        <textarea name="private_key" class="form-control" rows="5"
                            placeholder="-----BEGIN OPENSSH PRIVATE KEY-----&#10;...&#10;-----END OPENSSH PRIVATE KEY-----"
                            style="font-family:monospace;font-size:12px"></textarea>
                        <div class="form-hint">Dán nội dung file <code>~/.ssh/id_rsa</code> hoặc <code>id_ed25519</code></div>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Root Path *</label>
                    <input type="text" name="root_path" class="form-control" id="rootPathInput"
                        placeholder="/var/www/videos (SFTP) hoặc /videos (HTTP)">
                    <div class="form-hint" id="rootPathHint">Đường dẫn thư mục lưu video trên server.</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Base URL <span class="text-muted" style="text-transform:none;font-weight:400;font-size:.7rem">(để tạo link video)</span></label>
                    <input type="url" name="base_url" class="form-control" placeholder="https://cdn.example.com/videos">
                    <div class="form-hint">URL gốc để tạo link phát video.</div>
                </div>
                <button type="submit" class="btn btn-primary">➕ Thêm Server</button>
            </form>
        </div>
    </div>

    <!-- Server list -->
    <div>
        <div class="card-title" style="margin-bottom:.75rem;padding:.2rem 0">
            📋 Đã thêm (<%= servers.length %>)
        </div>
        <% if (servers.length===0) { %>
            <div class="empty-state">
                <div class="empty-state-icon">🖥️</div>
                <div class="empty-state-text">Chưa có server nào. Thêm server đầu tiên!</div>
            </div>
        <% } %>
        <div style="display:flex;flex-direction:column;gap:.75rem">
        <% servers.forEach(function(s){ %>
            <div class="server-card">
                <div class="server-card-header">
                    <div>
                        <div class="server-name"><%= s.name %></div>
                        <div class="server-host"><%= s.host ? s.host+(s.port?':'+s.port:'') : 'HTTP endpoint' %></div>
                    </div>
                    <div style="display:flex;align-items:center;gap:.5rem">
                        <span class="server-type-badge"><%= s.type.toUpperCase() %></span>
                        <span style="font-size:.75rem;color:<%= s.is_active?'var(--green)':'var(--red)' %>">
                            <%= s.is_active?'🟢 Active':'🔴 Off' %>
                        </span>
                    </div>
                </div>
                <div class="text-xs text-muted" style="margin-bottom:.5rem;font-family:monospace"><%= s.root_path %></div>
                <% if(s.base_url){ %>
                    <div class="text-xs text-secondary" style="margin-bottom:.5rem"><%= s.base_url %></div>
                <% } %>

                <%# Video stats (server-rendered, fast) %>
                <div class="text-xs" style="color:var(--text-muted);margin-bottom:.5rem">
                    📹 <strong style="color:var(--text-secondary)"><%= s.video_count %></strong> video
                    &nbsp;·&nbsp;
                    <strong style="color:var(--text-secondary)"><span class="fmtbytes"><%= s.video_size %></span></strong>
                </div>

                <%# Disk bar (async, loaded via JS) %>
                <div class="server-disk-wrap" data-server-id="<%= s.id %>" style="margin-bottom:.65rem">
                    <div class="disk-bar-header" style="display:flex;justify-content:space-between;font-size:.7rem;color:var(--text-muted);margin-bottom:.2rem">
                        <span class="disk-label">⏳ Đang tải dung lượng...</span>
                        <span class="disk-free" style="color:var(--accent-mid);font-weight:600"></span>
                    </div>
                    <div style="height:5px;border-radius:4px;background:var(--border-color);overflow:hidden">
                        <div class="disk-bar" style="height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent-start),var(--accent-end));width:0%;transition:width .6s ease"></div>
                    </div>
                </div>

                <div style="display:flex;gap:.5rem">
                    <button class="btn btn-xs btn-secondary" onclick="testServer(<%= s.id %>,this)">🔌 Test</button>
                    <button class="btn btn-xs btn-secondary" onclick="openEditServer(<%= s.id %>)">✏️ Sửa</button>
                    <button class="btn btn-xs btn-danger delete-server-btn" data-id="<%= s.id %>" data-name="<%= s.name %>">🗑️</button>
                </div>
            </div>
        <% }); %>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal-overlay" id="deleteServerModal" style="display:none">
    <div class="modal">
        <div class="modal-header">
            <span class="modal-title">🗑️ Xác nhận xóa</span>
            <button class="modal-close" onclick="closeDeleteModal()">✕</button>
        </div>
        <div class="modal-body">
            <p style="color:var(--text-secondary)">Bạn chắc chắn muốn xóa server <strong id="deleteServerName" style="color:var(--text-primary)"></strong>?</p>
            <p class="text-xs text-danger" style="margin-top:.5rem">Hành động này không thể hoàn tác.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeDeleteModal()">Hủy</button>
            <form id="deleteServerForm" method="POST" style="display:inline">
                <button type="submit" class="btn btn-danger">Xóa</button>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal-overlay" id="editServerModal" style="display:none">
    <div class="modal modal-lg">
        <div class="modal-header">
            <span class="modal-title">✏️ Sửa Server</span>
            <button class="modal-close" onclick="closeEditServer()">✕</button>
        </div>
        <form method="POST" id="editServerForm">
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Tên server</label>
                    <input type="text" name="name" id="esName" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Loại</label>
                    <select name="type" id="esType" class="form-control" onchange="toggleEditFields(this.value)">
                        <option value="sftp">🔐 SFTP</option>
                        <option value="http">🌐 HTTP</option>
                    </select>
                </div>
                <div id="esRemoteFields">
                    <div class="form-row">
                        <div class="form-group"><label class="form-label">Host</label><input type="text" name="host" id="esHost" class="form-control"></div>
                        <div class="form-group" style="max-width:110px"><label class="form-label">Port</label><input type="number" name="port" id="esPort" class="form-control"></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label class="form-label">Username</label><input type="text" name="username" id="esUsername" class="form-control"></div>
                        <div class="form-group"><label class="form-label">Password</label><input type="password" name="password" id="esPassword" class="form-control"></div>
                    </div>
                    <div class="form-group" id="esKeyGroup" style="display:none">
                        <label class="form-label">🔑 SSH Private Key</label>
                        <textarea name="private_key" id="esPrivateKey" class="form-control" rows="4"
                            style="font-family:monospace;font-size:12px"
                            placeholder="-----BEGIN OPENSSH PRIVATE KEY-----"></textarea>
                        <div class="form-hint">Để trống nếu giữ nguyên key cũ</div>
                    </div>
                </div>
                <div class="form-group"><label class="form-label">Root Path</label><input type="text" name="root_path" id="esRootPath" class="form-control" required></div>
                <div class="form-group"><label class="form-label">Base URL</label><input type="url" name="base_url" id="esBaseUrl" class="form-control"></div>
                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
                        <input type="checkbox" name="is_active" id="esIsActive" value="1" checked>
                        <span>Đang hoạt động</span>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeEditServer()">Hủy</button>
                <button type="submit" class="btn btn-primary">💾 Lưu</button>
            </div>
        </form>
    </div>
</div>

<script>
    function formatBytes(b){if(!b||b===0)return'0 B';const s=['B','KB','MB','GB','TB'];const i=Math.floor(Math.log(b)/Math.log(1024));return(b/Math.pow(1024,i)).toFixed(1)+' '+s[i];}

    // Format inline byte spans (server-rendered raw numbers)
    document.querySelectorAll('.fmtbytes').forEach(el=>{
        const n = parseInt(el.textContent, 10);
        el.textContent = isNaN(n) ? el.textContent : formatBytes(n);
    });

    async function loadDiskForServer(serverId) {
        const wrap = document.querySelector(`.server-disk-wrap[data-server-id="${serverId}"]`);
        if (!wrap) return;
        try {
            const res = await fetch(`/servers/disk/${serverId}`);
            const d = await res.json();
            const label = wrap.querySelector('.disk-label');
            const free  = wrap.querySelector('.disk-free');
            const bar   = wrap.querySelector('.disk-bar');
            if (!d.ok || !d.total) {
                label.textContent = 'Không có thông tin dung lượng';
                free.textContent  = '';
                bar.style.width   = '0%';
                return;
            }
            const usedPct = Math.min(100, Math.round((d.used / d.total) * 100));
            bar.style.width   = usedPct + '%';
            label.textContent = `Đã dùng: ${formatBytes(d.used)} / ${formatBytes(d.total)} (${usedPct}%)`;
            free.textContent  = formatBytes(d.free) + ' trống';
        } catch(_) {
            const label = wrap.querySelector('.disk-label');
            if (label) label.textContent = 'Không thể tải dung lượng';
        }
    }

    async function loadAllDiskStats() {
        const btn = document.getElementById('refreshStatsBtn');
        if (btn) { btn.disabled = true; btn.textContent = '⏳ Đang tải...'; }
        const wraps = document.querySelectorAll('.server-disk-wrap[data-server-id]');
        await Promise.all(Array.from(wraps).map(w => loadDiskForServer(w.dataset.serverId)));
        if (btn) { btn.textContent = '✅ Đã cập nhật'; setTimeout(()=>{ btn.textContent = '🔄 Cập nhật Disk'; btn.disabled = false; }, 2000); }
    }

    // Load disk stats on page load
    window.addEventListener('DOMContentLoaded', () => loadAllDiskStats());
</script>

<script>
    const serverData = <%- JSON.stringify(servers) %>;
</script>

<script>

    function toggleServerFields(type) {
        document.getElementById('remoteFields').style.display = '';
        const kg = document.getElementById('sftpKeyGroup');
        if(kg) kg.style.display = type==='sftp'?'':'none';
    }
    function toggleEditFields(type) {
        document.getElementById('esRemoteFields').style.display = '';
        const kg = document.getElementById('esKeyGroup');
        if(kg) kg.style.display = type==='sftp'?'':'none';
    }
    function openEditServer(id) {
        const s = serverData.find(x=>x.id===id); if(!s) return;
        document.getElementById('esName').value     = s.name;
        document.getElementById('esType').value     = s.type;
        document.getElementById('esHost').value     = s.host||'';
        document.getElementById('esPort').value     = s.port||'';
        document.getElementById('esUsername').value = s.username||'';
        document.getElementById('esPassword').value = '';
        document.getElementById('esPrivateKey').value = '';
        document.getElementById('esRootPath').value = s.root_path;
        document.getElementById('esBaseUrl').value  = s.base_url||'';
        document.getElementById('esIsActive').checked = !!s.is_active;
        document.getElementById('editServerForm').action = '/servers/edit/'+id;
        toggleEditFields(s.type);
        document.getElementById('editServerModal').style.display = 'flex';
    }
    function closeEditServer()  { document.getElementById('editServerModal').style.display='none'; }
    function closeDeleteModal() { document.getElementById('deleteServerModal').style.display='none'; }

    async function testServer(id, btn) {
        btn.disabled=true; btn.textContent='⏳...';
        try {
            const res  = await fetch('/servers/test/'+id,{method:'POST'});
            const data = await res.json();
            btn.textContent = data.ok?'✅ OK':'❌ Fail';
            btn.title = data.message;
            setTimeout(()=>{ btn.textContent='🔌 Test'; btn.disabled=false; },3000);
        } catch(e) { btn.textContent='❌ Error'; btn.disabled=false; }
    }

    document.addEventListener('click',function(e){
        const btn=e.target.closest('.delete-server-btn'); if(!btn) return;
        document.getElementById('deleteServerName').textContent = btn.dataset.name;
        document.getElementById('deleteServerForm').action = '/servers/delete/'+btn.dataset.id;
        document.getElementById('deleteServerModal').style.display = 'flex';
    });

    // Hiện SFTP fields mặc định khi tải trang
    window.addEventListener('DOMContentLoaded', () => {
        toggleServerFields('sftp');
    });
</script>

<%- include('footer') %>