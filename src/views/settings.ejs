<%- include('header') %>

    <div class="page-header">
        <h1 class="page-title">⚙️ Cài đặt & Cấu hình</h1>
    </div>

    <div class="card" style="max-width: 600px">
        <div class="card-header">
            <h3 class="card-title">🔧 Cài đặt hệ thống</h3>
        </div>
        <div class="card-body">
            <% if (typeof success !=='undefined' && success) { %>
                <div class="alert alert-success">
                    <%= success %>
                </div>
                <% } %>
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-error">
                            <%= error %>
                        </div>
                        <% } %>
                            <form method="POST" action="/settings">
                                <div class="form-group">
                                    <label class="form-label">🌐 Domain của hệ thống</label>
                                    <input type="url" name="domain" class="form-control"
                                        value="<%= settings.domain || 'http://localhost:3000' %>"
                                        placeholder="https://cdn.example.com">
                                    <p class="form-hint">Domain này sẽ được dùng để tạo link video. VD:
                                        <code>https://cdn.example.com</code></p>
                                </div>

                                <div class="form-group">
                                    <label class="form-label">🔑 API Key (để dùng API từ bên ngoài)</label>
                                    <div class="form-row">
                                        <input type="text" id="apiKeyInput" class="form-control"
                                            value="<%= settings.api_key || '' %>" readonly
                                            placeholder="Chưa có API key">
                                        <button type="button" class="btn btn-outline" onclick="generateApiKey()">🔄 Tạo
                                            mới</button>
                                    </div>
                                    <input type="hidden" name="api_key" id="apiKeyHidden"
                                        value="<%= settings.api_key || '' %>">
                                    <p class="form-hint">Dùng header <code>X-API-Key: &lt;key&gt;</code> khi gọi API</p>
                                </div>

                                <div class="divider"></div>
                                <h4 style="margin-bottom:1rem">📖 Hướng dẫn API</h4>
                                <div class="api-docs">
                                    <div class="api-endpoint">
                                        <span class="method get">GET</span>
                                        <code>/api/videos</code>
                                        <span class="text-muted">Lấy danh sách video</span>
                                    </div>
                                    <div class="api-endpoint">
                                        <span class="method get">GET</span>
                                        <code>/api/videos/:id/link</code>
                                        <span class="text-muted">Lấy link MP4</span>
                                    </div>
                                    <div class="api-endpoint">
                                        <span class="method post">POST</span>
                                        <code>/api/videos/upload</code>
                                        <span class="text-muted">Upload video (multipart)</span>
                                    </div>
                                    <div class="api-endpoint">
                                        <span class="method post">POST</span>
                                        <code>/api/videos/remote-upload</code>
                                        <span class="text-muted">Upload từ URL</span>
                                    </div>
                                    <div class="api-endpoint">
                                        <span class="method delete">DELETE</span>
                                        <code>/api/videos/:id</code>
                                        <span class="text-muted">Xóa video</span>
                                    </div>
                                </div>

                                <div class="mt-3">
                                    <button type="submit" class="btn btn-primary">💾 Lưu cài đặt</button>
                                </div>
                            </form>
        </div>
    </div>

    <script>
        function generateApiKey() {
            const key = 'vmgr_' + Array.from(crypto.getRandomValues(new Uint8Array(20))).map(b => b.toString(16).padStart(2, '0')).join('');
            document.getElementById('apiKeyInput').value = key;
            document.getElementById('apiKeyHidden').value = key;
        }
    </script>

    <%- include('footer') %>