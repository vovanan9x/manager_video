<%- include('header', { pageTitle: 'Upload Video - VideoManager' }) %>

<div class="page-header">
    <div>
        <h1 class="page-title">⬆️ Upload Video</h1>
    </div>
</div>

<% if (servers.length===0) { %>
    <div class="alert alert-warning">
        ⚠️ Chưa có server nào được cấu hình. Vui lòng <a href="/servers">thêm server</a> trước khi upload.
    </div>
<% } %>

<div class="card" style="max-width:820px;margin:0 auto">
    <div class="card-header">
        <div class="tab-group" id="uploadTabs">
            <button class="tab-btn active" data-tab="local">💾 Upload Local</button>
            <button class="tab-btn" data-tab="remote">🔗 Remote URL</button>
            <button class="tab-btn" data-tab="drive">🟢 Google Drive</button>
        </div>
    </div>
    <div class="card-body">
        <!-- Common fields -->
        <div class="form-group">
            <label class="form-label">Tiêu đề *</label>
            <input type="text" id="videoTitle" class="form-control" placeholder="Tên phim, tập phim..." required>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Server *</label>
                <select id="videoServer" class="form-control" onchange="onServerChange(this.value)">
                    <option value="">-- Chọn server --</option>
                    <% servers.forEach(function(s){ %>
                        <option value="<%= s.id %>"><%= s.name %> (<%= s.type %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Thư mục <span style="font-weight:400;text-transform:none;font-size:.72rem;color:var(--text-muted)">(tuỳ chọn)</span></label>
                <select id="videoFolder" class="form-control" onchange="saveSelect('folder',this.value)">
                    <option value="">-- Root --</option>
                </select>
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Mô tả</label>
            <textarea id="videoDesc" class="form-control" rows="2" placeholder="Mô tả phim..."></textarea>
        </div>

        <!-- Local Tab -->
        <div class="tab-content" id="tab-content-local">
            <div class="upload-dropzone" id="dropzone">
                <div class="dropzone-inner">
                    <div class="dropzone-icon">🎬</div>
                    <p>Kéo thả file video vào đây hoặc</p>
                    <label class="btn btn-secondary" style="cursor:pointer;margin-bottom:.5rem">
                        Chọn File
                        <input type="file" id="videoFile" accept=".mp4,.mkv,.avi,.mov,.webm,.flv" style="display:none">
                    </label>
                    <p class="text-muted text-xs">Hỗ trợ: .mp4 .mkv .avi .mov .webm .flv</p>
                    <div id="selectedFileName" class="selected-file-name" style="display:none"></div>
                </div>
            </div>
            <button class="btn btn-primary btn-full mt-2" id="uploadLocalBtn" onclick="startLocalUpload()" <%=servers.length===0?'disabled':''%>>
                ⬆️ Bắt đầu Upload
            </button>
        </div>

        <!-- Remote Tab -->
        <div class="tab-content" id="tab-content-remote" style="display:none">
            <div class="form-group">
                <label class="form-label">URL Video (.mp4, .mkv...)</label>
                <input type="url" id="remoteUrl" class="form-control" placeholder="https://example.com/video.mp4">
            </div>
            <button class="btn btn-primary btn-full" id="uploadRemoteBtn" onclick="startRemoteUpload()" <%=servers.length===0?'disabled':''%>>
                🔗 Bắt đầu Remote Upload
            </button>
        </div>

        <!-- Google Drive Tab -->
        <div class="tab-content" id="tab-content-drive" style="display:none">
            <div class="alert alert-success" style="margin-bottom:1rem">
                🟢 Nhập link Google Drive chia sẻ công khai. File sẽ được tải về máy chủ rồi upload lên server lưu trữ.
            </div>
            <div class="form-group">
                <label class="form-label">Link Google Drive *</label>
                <input type="text" id="driveUrl" class="form-control" placeholder="https://drive.google.com/file/d/FILE_ID/view">
                <div class="form-hint">Hỗ trợ: link chia sẻ / file ID trực tiếp</div>
            </div>
            <div class="form-group">
                <label class="form-label">Tên file <span style="font-weight:400;text-transform:none;font-size:.72rem;color:var(--text-muted)">(tuỳ chọn)</span></label>
                <input type="text" id="driveFilename" class="form-control" placeholder="vd: spider-man-ep1 (không cần đuôi .mp4)">
            </div>
            <button class="btn btn-primary btn-full" id="uploadDriveBtn" onclick="startDriveUpload()" <%=servers.length===0?'disabled':''%>>
                🟢 Bắt đầu Drive Upload
            </button>
        </div>

        <!-- Progress -->
        <div id="uploadProgress" style="display:none" class="upload-progress-section mt-3">
            <div class="progress-header">
                <span id="progressLabel">Đang chuẩn bị...</span>
                <span id="progressPct" style="color:var(--accent-mid);font-weight:700">0%</span>
            </div>
            <div class="progress-bar-container">
                <div class="progress-bar gradient-animated" id="progressBar" style="width:0%"></div>
            </div>
            <div id="progressStatus" class="text-muted text-xs mt-1"></div>
        </div>
    </div>
</div>

<div id="__appData" style="display:none"></div>
<script>
    const folderData = <%- JSON.stringify(folders) %>;
</script>

<script>
    function onServerChange(serverId) {
        saveSelect('server', serverId);
        const sel = document.getElementById('videoFolder');
        sel.innerHTML = '<option value="">-- Root --</option>';
        folderData.filter(f=>String(f.server_id)===String(serverId)).forEach(f=>{
            const depth = (f.path.match(/\//g)||[]).length;
            const opt = document.createElement('option');
            opt.value = f.id;
            opt.textContent = '\u00a0'.repeat(depth*4) + '📁 ' + f.path;
            sel.appendChild(opt);
        });
        const sv = localStorage.getItem('upload_folder');
        if(sv) sel.value = sv;
    }

    // Tabs
    document.querySelectorAll('.tab-btn').forEach(btn=>{
        btn.addEventListener('click',()=>{
            document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c=>c.style.display='none');
            btn.classList.add('active');
            document.getElementById('tab-content-'+btn.dataset.tab).style.display='';
            localStorage.setItem('upload_active_tab', btn.dataset.tab);
        });
    });

    // File input
    document.getElementById('videoFile').addEventListener('change',function(){
        const f=this.files[0]; if(!f) return;
        const el=document.getElementById('selectedFileName');
        el.textContent='📎 '+f.name+' ('+formatBytes(f.size)+')';
        el.style.display='';
    });

    // Drag & Drop
    const dz=document.getElementById('dropzone');
    dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag-over');});
    dz.addEventListener('dragleave',()=>dz.classList.remove('drag-over'));
    dz.addEventListener('drop',e=>{
        e.preventDefault(); dz.classList.remove('drag-over');
        const file=e.dataTransfer.files[0]; if(!file) return;
        const input=document.getElementById('videoFile');
        const dt=new DataTransfer(); dt.items.add(file); input.files=dt.files;
        const el=document.getElementById('selectedFileName');
        el.textContent='📎 '+file.name+' ('+formatBytes(file.size)+')';
        el.style.display='';
    });

    function getCommonData(){
        return {
            title: document.getElementById('videoTitle').value.trim(),
            description: document.getElementById('videoDesc').value.trim(),
            server_id: document.getElementById('videoServer').value,
            folder_id: document.getElementById('videoFolder').value,
        };
    }

    function showProgress(show){ document.getElementById('uploadProgress').style.display=show?'':'none'; }
    function updateProgress(pct,label,status){
        document.getElementById('progressBar').style.width=pct+'%';
        document.getElementById('progressPct').textContent=pct+'%';
        document.getElementById('progressLabel').textContent=label;
        document.getElementById('progressStatus').textContent=status;
    }

    function startSseForVideo(videoId){
        const es=new EventSource('/videos/progress/'+videoId);
        es.onmessage=(e)=>{
            const d=JSON.parse(e.data);
            if(d.status==='done'){ updateProgress(100,'✅ Upload hoàn thành!','Đang chuyển trang...'); es.close(); setTimeout(()=>window.location.href='/videos',1500); }
            else if(d.status==='error'){ updateProgress(d.progress,'❌ Lỗi upload','Đã xảy ra lỗi'); es.close(); }
            else if(d.status==='stopped'){ updateProgress(0,'⏹ Đã dừng',''); es.close(); }
            else{ updateProgress(d.progress,'⏳ Đang upload...', d.progress+'% hoàn thành'); }
        };
    }

    function startLocalUpload(){
        const c=getCommonData();
        if(!c.title) return alert('Vui lòng nhập tiêu đề');
        if(!c.server_id) return alert('Vui lòng chọn server');
        const file=document.getElementById('videoFile').files[0];
        if(!file) return alert('Vui lòng chọn file video');
        const fd=new FormData();
        Object.entries(c).forEach(([k,v])=>fd.append(k,v));
        fd.append('video',file);

        showProgress(true);
        updateProgress(0,'⬆️ Đang gửi file lên server...','0%');
        document.getElementById('uploadLocalBtn').disabled=true;

        const xhr=new XMLHttpRequest();

        // Real-time upload progress (bytes sent → server)
        xhr.upload.addEventListener('progress',function(ev){
            if(!ev.lengthComputable) return;
            const pct=Math.round((ev.loaded/ev.total)*100);
            const sent=formatBytes(ev.loaded), total=formatBytes(ev.total);
            updateProgress(pct,'⬆️ Đang gửi file lên server...', sent+' / '+total);
        });

        // Upload bytes done, server đang xử lý
        xhr.upload.addEventListener('load',function(){
            updateProgress(100,'⚙️ Server đang xử lý...','Vui lòng chờ...');
        });

        xhr.addEventListener('load',function(){
            document.getElementById('uploadLocalBtn').disabled=false;
            try{
                const data=JSON.parse(xhr.responseText);
                if(data.success) startSseForVideo(data.videoId);
                else updateProgress(0,'❌ '+(data.error||'Lỗi'),'');
            }catch(e){ updateProgress(0,'❌ Lỗi phản hồi server',''); }
        });

        xhr.addEventListener('error',function(){
            document.getElementById('uploadLocalBtn').disabled=false;
            updateProgress(0,'❌ Lỗi kết nối','Kiểm tra mạng và thử lại');
        });

        xhr.addEventListener('abort',function(){
            document.getElementById('uploadLocalBtn').disabled=false;
            updateProgress(0,'⏹ Đã huỷ','');
        });

        xhr.open('POST','/videos/upload/local');
        xhr.send(fd);
    }

    async function startRemoteUpload(){
        const c=getCommonData();
        if(!c.title) return alert('Vui lòng nhập tiêu đề');
        if(!c.server_id) return alert('Vui lòng chọn server');
        const url=document.getElementById('remoteUrl').value.trim();
        if(!url) return alert('Vui lòng nhập URL video');
        showProgress(true); updateProgress(0,'⏳ Đang khởi tạo...','Đang kết nối...');
        try{
            const res=await fetch('/videos/upload/remote',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({...c,url})});
            const data=await res.json();
            if(data.success) startSseForVideo(data.videoId);
            else updateProgress(0,'❌ '+(data.error||'Lỗi'),'');
        }catch(err){ updateProgress(0,'❌ Lỗi kết nối',err.message); }
    }

    async function startDriveUpload(){
        const c=getCommonData();
        if(!c.title) return alert('Vui lòng nhập tiêu đề');
        if(!c.server_id) return alert('Vui lòng chọn server');
        const driveUrl=document.getElementById('driveUrl').value.trim();
        if(!driveUrl) return alert('Vui lòng nhập link Google Drive');
        const filename=document.getElementById('driveFilename').value.trim();
        showProgress(true); updateProgress(0,'⏳ Đang kết nối Drive...','Đang trích xuất file ID...');
        try{
            const res=await fetch('/api/videos/drive-upload',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({...c,drive_url:driveUrl,filename:filename||undefined})});
            const data=await res.json();
            if(data.success){ updateProgress(0,'⏳ Đang tải từ Drive...','File ID: '+(data.fileId||'')); startSseForVideo(data.videoId); }
            else updateProgress(0,'❌ '+(data.error||'Lỗi'),'');
        }catch(err){ updateProgress(0,'❌ Lỗi kết nối',err.message); }
    }

    function formatBytes(b){if(!b)return'0 B';const s=['B','KB','MB','GB','TB'];const i=Math.floor(Math.log(b)/Math.log(1024));return(b/Math.pow(1024,i)).toFixed(1)+' '+s[i];}

    // Restore state
    window.addEventListener('DOMContentLoaded',()=>{
        ['server','folder'].forEach(key=>{
            const val=localStorage.getItem('upload_'+key);
            if(val){
                const el=document.getElementById('video'+key.charAt(0).toUpperCase()+key.slice(1));
                if(el){ el.value=val; if(key==='server') onServerChange(val); }
            }
        });
        const tab=localStorage.getItem('upload_active_tab');
        if(tab){ const btn=document.querySelector('[data-tab="'+tab+'"]'); if(btn) btn.click(); }
    });
    function saveSelect(key,val){ localStorage.setItem('upload_'+key,val); }
</script>

<%- include('footer') %>